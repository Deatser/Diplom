# Адрес твоего Socket.io сервера (Render) для ПРОДАКШЕН-сборки.
# Нужен, потому что на Яндексе window.location.origin указывает на их CDN, а не
# на твой сервер. Обязательно wss:// (секьюрный) — иначе Яндекс по HTTPS заблокирует.
#
# ⚠️ ПРОВЕРЬ адрес в дашборде Render (Dashboard → твой сервис → строка вверху).
#    Если там не left2solve.onrender.com — впиши свой.
VITE_WS_URL=wss://left2solve.onrender.com
